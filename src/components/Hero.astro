---
import { profile } from "../data/resume";
---

<section id="top" class="mx-auto max-w-content px-6 pb-6 pt-20 sm:pt-28">
  <div class="reveal is-visible">
    <img
      class="h-20 w-20 rounded-full border-2 border-pine-900/10 shadow-sm sm:h-24 sm:w-24"
      src="/images/avatar.jpg"
      alt="Portrait of Patrick McAlinden"
      width="96"
      height="96"
    />
    <h1 class="mt-8 font-display text-4xl font-bold leading-tight text-pine-950 sm:text-5xl">
      {profile.name}
    </h1>
    <p class="mt-4 text-lg text-pine-800">
      {profile.role} at {profile.company} · {profile.location}
    </p>
    <p class="mt-3 max-w-xl text-pine-800/80">
      {profile.tagline}
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href={`mailto:${profile.email}`}
        class="rounded-full bg-pine-900 px-5 py-2.5 text-sm font-medium text-cream-100 transition-colors duration-200 hover:bg-pine-700">
        Email me
      </a>
      <a
        href="https://www.linkedin.com/in/patrick-mcalinden/"
        class="rounded-full border border-pine-900/20 px-5 py-2.5 text-sm font-medium text-pine-900 transition-colors duration-200 hover:border-pine-600 hover:text-pine-600">
        LinkedIn
      </a>
      <a
        href="https://github.com/patrickmcalinden"
        class="rounded-full border border-pine-900/20 px-5 py-2.5 text-sm font-medium text-pine-900 transition-colors duration-200 hover:border-pine-600 hover:text-pine-600">
        GitHub
      </a>
    </div>
  </div>
</section>
