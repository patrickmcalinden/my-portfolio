---
import Section from "./Section.astro";
import { contact, profile } from "../data/resume";
---

<Section id="contact" title="Contact">
  <p class="max-w-xl text-pine-800/90">
    I'm always happy to talk data, dashboards, or new opportunities. The
    fastest way to reach me is email.
  </p>
  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    {
      contact.map((item) => (
        <a
          href={item.link}
          class="group rounded-2xl border border-cream-200 bg-cream-100 px-5 py-4 transition-colors duration-200 hover:border-pine-600/50">
          <p class="text-sm font-medium uppercase tracking-wide text-pine-700">
            {item.type}
          </p>
          <p class="mt-1 truncate text-sm text-pine-900 group-hover:text-pine-600">
            {item.title} <span aria-hidden="true">↗</span>
          </p>
        </a>
      ))
    }
  </div>
</Section>

<footer class="border-t border-cream-200">
  <div class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-2 px-6 py-8 text-sm text-pine-800/60">
    <p>{`© ${new Date().getFullYear()} ${profile.name}`}</p>
    <p>Built with Astro & Tailwind</p>
  </div>
</footer>
