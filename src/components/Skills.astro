---
import Section from "./Section.astro";
import { skills } from "../data/resume";
---

<Section id="skills" title="Skills">
  <div class="space-y-8">
    {
      skills.map((group) => (
        <div>
          <p class="text-sm font-medium uppercase tracking-wide text-pine-700">
            {group.label}
          </p>
          <ul class="mt-3 flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <li class="rounded-full border border-cream-300 bg-cream-100 px-3.5 py-1.5 text-sm text-pine-900 transition-colors duration-200 hover:border-pine-600">
                {skill}
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</Section>
