---
import Section from "./Section.astro";
import { projects } from "../data/resume";
---

<Section id="projects" title="Projects">
  <div class="grid gap-4 sm:grid-cols-2">
    {
      projects.map((project) => (
        <a
          href={project.link}
          class="group flex flex-col rounded-2xl border border-cream-200 bg-cream-100 p-6 transition-all duration-200 hover:-translate-y-1 hover:border-pine-600/50 hover:shadow-lg hover:shadow-pine-900/5">
          <div class="flex items-start justify-between gap-2">
            <h3 class="font-display text-lg font-semibold text-pine-950 group-hover:text-pine-700">
              {project.title}
            </h3>
            <span
              class="text-pine-600 transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
              aria-hidden="true">
              ↗
            </span>
          </div>
          <p class="mt-2 flex-1 text-sm text-pine-800/80">{project.description}</p>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            {project.tags.map((tag) => (
              <span class="rounded-full bg-pine-900/5 px-2.5 py-0.5 text-xs font-medium text-pine-800">
                {tag}
              </span>
            ))}
            <span class="ml-auto text-xs text-pine-800/50">{project.date}</span>
          </div>
        </a>
      ))
    }
  </div>
</Section>
